# Copy to .env and fill in.
#
# Only VLLM_HOST_MODELS_DIR is strictly required.
# Everything else has a sensible default.

# Absolute host path to your HuggingFace model cache directory.
# Must contain hub/ subdirectory with the AWQ-INT4 snapshot already
# fetched (see Quick start in README.md):
#   hf download cyankiwi/Qwen3.6-27B-AWQ-INT4 --cache-dir $VLLM_HOST_MODELS_DIR/hub
VLLM_HOST_MODELS_DIR=/absolute/path/to/hf-cache

# HuggingFace token. The cyankiwi AWQ-INT4 quant is public (apache-2.0)
# but the base Qwen/Qwen3.6-27B card is gated, so download paths that
# resolve through the base model still need a token. Mint a read token
# at https://huggingface.co/settings/tokens and paste it here. Only
# used by `hf download` at cache-fill time; not needed at runtime
# (HF_HUB_OFFLINE=1 inside the container).
HF_TOKEN=hf_your_token_here

# Host-side directories for persistent JIT caches (survive container
# restarts so subsequent boots skip the ~3 min kernel compile).
# Defaults to repo-local .triton-cache/ and .vllm-cache/ if unset.
#VLLM_HOST_TRITON_CACHE=/absolute/path/to/triton-cache
#VLLM_HOST_VLLM_CACHE=/absolute/path/to/vllm-cache

# Loopback-only host port. Change if 8000 is taken.
VLLM_HOST_PORT=8000

# Model ID or local path. The default is the AWQ-INT4 quant we tested.
# `cyankiwi/Qwen3.6-27B-AWQ-INT4` is a 4-bit AWQ (compressed-tensors
# scheme, group_size 128) that preserves the vision tower so /v1/chat
# image inputs and the Qwen3VL preprocessor still work.
VLLM_MODEL_ID=cyankiwi/Qwen3.6-27B-AWQ-INT4
VLLM_SERVED_MODEL_NAME=Qwen3.6-27B-AWQ4

# Concurrent serving slots. Default is 1 (single-stream) for clean
# prefill measurement and lowest-latency single-client use. Production
# default for the daily driver is 3 (verified: 3 simultaneous clients
# decoded without OOM or contention; per-stream ~13.5 t/s, aggregate
# ~41 t/s peak). AWQ4 frees ~37 GiB of UMA vs BF16, so headroom for a
# few extra slots is real on this hardware.
VLLM_MAX_NUM_SEQS=1

# GPU memory utilization: hard CAP on the fraction of UMA vLLM may
# claim. NOT a target. **Right-size to your actual concurrency x
# context, do not pick 0.9 reflexively.** At low MAX_NUM_SEQS with
# util=0.9 vLLM still allocates a KV pool sized to the cap, and most
# of it sits unused (single-stream cannot consume an 80+ GiB KV pool).
# Suggested values:
#   0.5  -> ~64 GiB cap, fits the production 3-stream profile and
#           leaves ~75 GiB of UMA free for sibling services on the box
#   0.7  -> ~90 GiB cap, more KV headroom for 3-up if needed
#   0.9  -> ~115 GiB cap, only useful if you genuinely want one client
#           with the full 256K context AND don't share the box
# Lower further (e.g. 0.45) if the DeltaNet GDN Triton autotuner OOMs
# on the first real request (vllm#36598).
VLLM_GPU_MEMORY_UTIL=0.55

# Max context window. Native max for Qwen 3.6 27B is 262144 (256K).
# Reducing this does NOT save compute  -  it only caps the longest prompt
# you can send AND shrinks the per-slot KV reservation. Default 65536
# (64K) is the comfortable shipping point with the AWQ-INT4 MMQ HIP
# kernel (Patch 16): the kernel adds ~22 GiB of dual-storage weight
# memory (so decode can fall through to TritonW4A16 at M < 32 without
# per-call repack), and 64K KV per slot fits cleanly under the 0.55
# util cap. Raise to 131072 / 262144 if you accept the tighter memory
# budget; drop further if you need more sibling-service headroom.
VLLM_MAX_MODEL_LEN=65536

# Scheduler token budget per iteration. Default in vLLM v0.20.0 online
# serving is 8192. Bumping to 16384 lets long prefills (4k+ tokens)
# land in fewer chunks, which helps TTFT on long prompts. Tradeoff:
# more KV pressure when batching many concurrent decodes. Leave unset
# (8192) for production multi-stream; opt in to 16384 for single-
# stream prefill-TTFT-sensitive workloads.
#VLLM_MAX_NUM_BATCHED_TOKENS=8192

# vLLM ref to build. Defaults to the v0.20.0 release tag (2026-04-23),
# which contains:
#   - PR #36505: AWQMarlin on ROCm (+57% prefill / +73% decode for AWQ)
#   - RDNA 3.5/4 device-ID detection (gfx1150/1151/1201)
#   - Initial GDN attention for Qwen3-Next / Qwen3.5
#
# Set to a sha or branch name to override. Leave empty to track HEAD.
# Note: tool-call parser PRs vllm#40783 (open), #40785 (closed
# unmerged), #40787 (closed unmerged) are NOT in 0.20.0; streaming
# tool calls remain fragile. Pin to a post-merge sha if/when the
# refactor lands.
VLLM_COMMIT=v0.20.0
