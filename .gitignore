# Secrets  -  only .env.template is committed
.env
.env.local
*.key
*.pem

# Research data (deep-research findings, may contain proprietary insight)
.research/

# Local working tree (cloned reference repos, scratch space)
tmp/
logs/

# Session history preserved locally but not shipped
.tests/

# Local helpers (qwen-cli, repo metadata)  -  kept hidden, not shipped
.tools/

# Benchmark output (regenerated each run)
test/*.json
test/results/

# JIT caches (regenerated each run, large)
.triton-cache/
.vllm-cache/

# Python
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.venv/
venv/

# C/HIP custom-op build artifacts (rebuilt on demand inside the container)
csrc/**/build/
csrc/**/*.so
# hipify auto-generates *_hip.{hip,cpp,h} alongside the originals; only commit the originals
csrc/**/*_hip.hip
csrc/**/*_hip.cpp
csrc/**/*_hip.h

# Scratch session notes
session.txt

# Claude Code local config / scheduled-task state (per-project, not shared)
.claude/

# Editors / IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS junk
.DS_Store
Thumbs.db

# Logs / tmp
*.log
*.tmp

# Model weights should never be in the repo
*.safetensors
*.gguf
*.bin
models/
